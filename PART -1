import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# LOAD DATA

df = pd.read_csv("data/train.csv")

print("First 5 Rows")
print(df.head())

print("\nData Types")
print(df.dtypes)

print("\nShape")
print(df.shape)

# NULL VALUE ANALYSIS

null_count = df.isnull().sum()
null_percent = (null_count / len(df)) * 100

null_table = pd.DataFrame({
    "Null Count": null_count,
    "Null %": null_percent
})

print("\nNull Analysis")
print(null_table.sort_values("Null %", ascending=False))

high_null_cols = null_table[null_table["Null %"] > 20]

print("\nColumns with >20% Nulls")
print(high_null_cols)

# Fill columns below 20%

for col in df.columns:
    if df[col].isnull().mean()*100 < 20:

        if pd.api.types.is_numeric_dtype(df[col]):
            df[col] = df[col].fillna(df[col].median())

# DUPLICATES

duplicates = df.duplicated().sum()

print(f"\nDuplicate Rows: {duplicates}")

null_before = df.isnull().mean()*100

df = df.drop_duplicates()

null_after = df.isnull().mean()*100

print(f"Rows removed: {duplicates}")

# DATA TYPE CORRECTION

memory_before = df.memory_usage(deep=True).sum()

# Example conversion
df["MSSubClass"] = df["MSSubClass"].astype(str)

# category conversion
df["Neighborhood"] = df["Neighborhood"].astype("category")

memory_after = df.memory_usage(deep=True).sum()

print("\nMemory Before")
print(memory_before)

print("\nMemory After")
print(memory_after)

# DESCRIPTIVE STATS

numeric_cols = df.select_dtypes(include=np.number).columns

print(df[numeric_cols].describe())

skewness = df[numeric_cols].skew()

print("\nSkewness")
print(skewness.sort_values(ascending=False))

most_skewed = skewness.abs().idxmax()

print("\nMost skewed variable:", most_skewed)

# OUTLIER DETECTION

outlier_columns = ["SalePrice", "GrLivArea"]

for col in outlier_columns:

    Q1 = df[col].quantile(0.25)
    Q3 = df[col].quantile(0.75)

    IQR = Q3 - Q1

    lower = Q1 - 1.5*IQR
    upper = Q3 + 1.5*IQR

    outliers = df[
        (df[col] < lower) | (df[col] > upper)
    ]

    print(f"\n{col}")
    print("Outliers:", len(outliers))

# LINE PLOT

plt.figure(figsize=(10,5))

plt.plot(df["SalePrice"])

plt.title("Sale Price Trend")
plt.xlabel("Row Index")
plt.ylabel("Sale Price")

plt.savefig("plots/line_plot.png")
plt.close()

# BAR CHART

mean_price = df.groupby("Neighborhood")["SalePrice"].mean().sort_values()

plt.figure(figsize=(12,6))

mean_price.plot(kind="bar")

plt.title("Average SalePrice by Neighborhood")
plt.xlabel("Neighborhood")
plt.ylabel("Mean SalePrice")

plt.tight_layout()

plt.savefig("plots/bar_chart.png")
plt.close()

# HISTOGRAM

plt.figure(figsize=(8,5))

sns.histplot(df[most_skewed], bins=20)

plt.title(f"Histogram of {most_skewed}")

plt.savefig("plots/histogram_skewed.png")
plt.close()

# SCATTER PLOT


plt.figure(figsize=(8,6))

sns.scatterplot(
    data=df,
    x="GrLivArea",
    y="SalePrice"
)

plt.title("GrLivArea vs SalePrice")

plt.savefig("plots/scatter_plot.png")
plt.close()

# BOXPLOT

plt.figure(figsize=(12,6))

sns.boxplot(
    data=df,
    x="Neighborhood",
    y="SalePrice"
)

plt.xticks(rotation=90)

plt.title("SalePrice by Neighborhood")

plt.tight_layout()

plt.savefig("plots/box_plot.png")
plt.close()

# CORRELATION HEATMAP

corr_matrix = df[numeric_cols].corr()

plt.figure(figsize=(14,10))

sns.heatmap(
    corr_matrix,
    cmap="coolwarm"
)

plt.title("Correlation Heatmap")

plt.savefig("plots/correlation_heatmap.png")
plt.close()

print(corr_matrix)

# MEAN VS MEDIAN

top_skew = skewness.abs().sort_values(
    ascending=False
).head(2).index

for col in top_skew:

    print(f"\nColumn: {col}")
    print("Mean:", df[col].mean())
    print("Median:", df[col].median())

    df[col] = df[col].fillna(df[col].median())

print("\nRemaining Nulls")
print(df[top_skew].isnull().sum())

# SPEARMAN CORRELATION

pearson = df[numeric_cols].corr(method="pearson")
spearman = df[numeric_cols].corr(method="spearman")

print("\nPearson")
print(pearson)

print("\nSpearman")
print(spearman)

pairs = []

for i in range(len(numeric_cols)):
    for j in range(i+1, len(numeric_cols)):

        col1 = numeric_cols[i]
        col2 = numeric_cols[j]

        diff = abs(
            spearman.loc[col1,col2]
            -
            pearson.loc[col1,col2]
        )

        pairs.append(
            [col1,col2,diff]
        )

diff_df = pd.DataFrame(
    pairs,
    columns=["Column1","Column2","Diff"]
)

top3 = diff_df.sort_values(
    "Diff",
    ascending=False
).head(3)

print("\nTop 3 Differences")
print(top3)

# GROUP AGGREGATION

agg = df.groupby(
    "Neighborhood"
)["SalePrice"].agg(
    ["mean","std","count"]
)

print("\nAggregation")
print(agg)

highest_mean = agg["mean"].idxmax()
highest_std = agg["std"].idxmax()

print("\nHighest Mean Group:", highest_mean)
print("Highest Std Group:", highest_std)

ratio = agg["mean"].max() / agg["mean"].min()

print("\nMean Ratio:", ratio)

# SAVE CLEAN DATA

df.to_csv(
    "cleaned_data.csv",
    index=False
)

print("\ncleaned_data.csv saved")
